{
  "name": "demo-app",
  "private": true,
  "version": "1.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5050",
    "assets:generate:android": "npx capacitor-assets generate --android",
    "build": "vite build",
    "build:sync:android": "npx cap sync android",
    "build:copy:android": "npx cap copy android",
    "build:debugApp:android": "cd android && ./gradlew assembleDebug",
    "build:releaseApp:android": "cd android && ./gradlew bundleRelease",
    "build:all": "npm run build && npm run build:sync:android && npm run build:copy:android && npm run build:debugApp:android && npm run build:releaseApp:android",
    "release": "node scripts/release.mjs",
    "preview": "vite preview --port 6060",
    "map:download-sprites": "node scripts/downloadProtomapsSprites.mjs"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "keywords": [
    "Hybrid Web App",
    "SPA",
    "Svelte.js",
    "Capacitor.js"
  ],
  "author": "NИ Dmitry Adamov",
  "license": {
    "type": "MIT",
    "url": "https://opensource.org/license/mit"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "svelte": "^5.55.7",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/device": "^8.0.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@mateothegreat/svelte5-router": "^2.16.19",
    "@protomaps/basemaps": "^5.7.2",
    "capacitor-native-settings": "^8.1.0",
    "i18next": "^26.2.0",
    "konsta": "^5.0.9",
    "maplibre-gl": "^5.24.0",
    "pmtiles": "^4.4.1"
  }
}
